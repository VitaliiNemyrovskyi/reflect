# Reflect production env — copy to /opt/reflect/.env on the VPS and fill in.
# This file is committed; the real `.env` is gitignored.

# ─── LLM provider ───
# `anthropic` uses ANTHROPIC_API_KEY (paid, fast, best quality).
# `openrouter` uses OPENROUTER_API_KEY (free tier with `openrouter/owl-alpha`).
# Default in code is `anthropic`, but for the temporary deploy we use openrouter
# to avoid burning Anthropic credits while validating with the wife.
LLM_PROVIDER=openrouter

# Per-call model overrides — leave blank for the provider's defaults.
# Anthropic defaults:  claude-sonnet-4-6 (chat) / claude-opus-4-7 (feedback)
# OpenRouter defaults: openrouter/owl-alpha for both
LLM_MODEL_CHAT=
LLM_MODEL_FEEDBACK=

ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# ─── JWT secrets ───
# Generate with:  openssl rand -base64 48
# Both must be set, must be DIFFERENT, and rotating one invalidates all
# refresh tokens (effectively a global logout).
JWT_ACCESS_SECRET=REPLACE_ME_RUN_OPENSSL_RAND_BASE64_48
JWT_REFRESH_SECRET=REPLACE_ME_RUN_OPENSSL_RAND_BASE64_48
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── OAuth (optional) ───
# Add `https://reflect.swift-mail.app/api/auth/google/callback` to the
# Google Cloud Console OAuth client's "Authorized redirect URIs" before
# enabling. Same for Facebook.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── Cloudflare ───
# Caddy uses this for DNS-01 ACME challenge to get the Let's Encrypt cert
# for reflect.swift-mail.app. Token must have:
#   Zone → Zone → Read   (any zone)
#   Zone → DNS → Edit    (specifically the swift-mail.app zone)
# Same token already used by deploy/setup-cloudflare-dns.sh logic.
CLOUDFLARE_API_TOKEN=

# ─── Image tag ───
# Pinned via CI in the future; for now `latest` is rebuilt on every deploy.
IMAGE_TAG=latest
