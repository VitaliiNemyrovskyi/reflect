# Кореневий .env — Nest читає його при старті (через @nestjs/config + dotenv)

# Який LLM-провайдер використовуємо: "anthropic" або "openrouter".
# - anthropic: платний, prompt caching, Sonnet 4.6 / Opus 4.7
# - openrouter: безкоштовно (50 req/day, 20 req/min), Qwen3 / NVIDIA NeMotron
LLM_PROVIDER=openrouter

# Anthropic — потрібен лише якщо LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — потрібен лише якщо LLM_PROVIDER=openrouter
# Ключ: https://openrouter.ai/settings/keys (Google-логін, без картки)
OPENROUTER_API_KEY=sk-or-v1-...

# Моделі (опційно — без них візьмуться розумні дефолти для обраного провайдера)
# anthropic дефолти: claude-sonnet-4-6 / claude-opus-4-7
# openrouter дефолти: openrouter/owl-alpha (1M контекст, безкоштовна, добре говорить
# українською). Інші free-моделі (qwen, llama, gemma, deepseek) часто перевантажені
# upstream-провайдерами — лишай owl-alpha, поки не мігруємо на платний тариф.
# LLM_MODEL_CHAT=
# LLM_MODEL_FEEDBACK=

# ElevenLabs (опційно). Якщо порожньо — фронт використовує browser SpeechSynthesis.
# Реєстрація: https://elevenlabs.io (free 10K симв/міс, multilingual_v2 модель тримає українську).
# Voice ID за замовчуванням — Charlotte (молодий жіночий, multilingual). Інші голоси:
# https://elevenlabs.io/app/voice-library — копіюй Voice ID на свій вибір.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa
ELEVENLABS_MODEL=eleven_multilingual_v2

# Порт API. Не використовуй PORT — Angular CLI/preview-хост уже використовує цю
# назву для свого dev-server, тому Nest читає API_PORT.
API_PORT=3000

# Prisma + SQLite. Шлях відносно backend/prisma/schema.prisma
DATABASE_URL="file:../reflect.db"

# JWT (обов'язкове). У продакшні згенеруй унікальні: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Google OAuth (опційно — без них кнопка «Login with Google» прихована).
# console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (опційно). developers.facebook.com → My Apps → Create App
# → Facebook Login → Settings → Valid OAuth Redirect URIs:
#   http://localhost:3000/api/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Куди редіректити після успішного OAuth-callback'а
FRONTEND_URL=http://localhost:4200
