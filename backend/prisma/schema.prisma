generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id             Int       @id @default(autoincrement())
  slug           String    @unique
  displayName    String
  profileText    String
  diagnosis      String?   // Ukrainian-language clinical label shown on UI (truncated to fit cards)
  diagnosisCode  String?   // English DSM-5/ICD code shown as tooltip — for students who want to look up literature
  difficulty     Int?      // 1-5; behavioral difficulty (how hard to engage). Modulates LLM behavior.
  complexity     Int?      // 1-5; clinical severity (how serious the case is). Informational, doesn't change LLM.
  avatarUrl      String?   // Link to portrait
  createdAt      DateTime  @default(now())
  sessions       Session[]
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  hashedPassword  String?  // null for OAuth-only users
  displayName     String?
  bio             String?  // free-text "about me" — year of study, modality interests, etc.
  provider        String   @default("local") // "local" | "google" | "facebook"
  providerUserId  String?  // OAuth subject id
  refreshTokenHash String?
  // Per-user UI preferences serialized as JSON. Schema is loose — clients
  // merge new keys via PATCH. Today: { hintsEnabled: boolean }.
  preferencesJson String?
  // Admin role — bypasses session-ownership checks, sees other users'
  // data, browses error logs. Bootstrapped via ADMIN_EMAILS env var on
  // each login/refresh/me, so granting admin doesn't require manual SQL.
  isAdmin         Boolean  @default(false)
  createdAt       DateTime @default(now())
  sessions        Session[]
  errorLogs       ErrorLog[]
}

/**
 * Captured exceptions for admin debugging. Populated by a global
 * NestJS ExceptionFilter — only 500-class server errors (anything that's
 * not a client mistake like 401/403/404/etc.) end up here.
 *
 * userId/sessionId stay nullable so the row survives if those parents
 * are deleted (we set the FK to SetNull instead of cascade — useful
 * when investigating an error that DROPPED a session).
 */
model ErrorLog {
  id         Int       @id @default(autoincrement())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     Int?
  sessionId  Int?      // NOT a FK — sessions can be discarded by users
  endpoint   String    // request path, e.g. /api/sessions/12/end-stream
  method     String    // HTTP method
  status     Int       // HTTP status
  message    String    // truncated to ~500 chars
  stack      String?   // truncated to ~3000 chars; null if not exposed
  createdAt  DateTime  @default(now())

  @@index([createdAt])
  @@index([userId])
}

model Session {
  id              Int       @id @default(autoincrement())
  character       Character @relation(fields: [characterId], references: [id])
  characterId     Int
  user            User?     @relation(fields: [userId], references: [id])
  userId          Int?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  feedback        String?           // Narrative feedback (Markdown)
  feedbackJson    String?           // Structured supervisor JSON (assessment metrics)
  patientMemory   String?           // Anna's first-person memory of this session for next time
  messages        Message[]
  notes           Note[]

  @@index([characterId])
  @@index([userId])
}

model Message {
  id        Int      @id @default(autoincrement())
  // Cascade — when a session is discarded ("як така що не розпочиналась"),
  // all its messages disappear with it. Prevents orphan rows that would
  // otherwise block Session.delete with a FK constraint error.
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId Int
  role      String
  content   String
  createdAt DateTime @default(now())
  notes     Note[]

  @@index([sessionId])
}

model Note {
  id               Int      @id @default(autoincrement())
  // Cascade — same reasoning as Message: a discarded session takes its
  // notes with it.
  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId        Int
  // anchorMessage stays nullable + default SetNull on Message delete, so
  // notes referencing a deleted message just lose their anchor (rare path
  // since usually messages only get deleted as part of a session cascade).
  anchorMessage    Message? @relation(fields: [anchorMessageId], references: [id])
  anchorMessageId  Int?
  anchorText       String?
  noteText         String
  createdAt        DateTime @default(now())

  @@index([sessionId])
}
